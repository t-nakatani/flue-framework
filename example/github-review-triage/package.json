{
  "name": "flue-github-review-triage-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "check": "tsc --noEmit",
    "triage:example": "flue run triage-issue --target node --payload '{\"owner\":\"OWNER\",\"repo\":\"REPO\",\"issueNumber\":123,\"apply\":false}'",
    "review:example": "flue run review-pr --target node --payload '{\"owner\":\"OWNER\",\"repo\":\"REPO\",\"pullNumber\":123,\"apply\":false}'"
  },
  "dependencies": {
    "@flue/runtime": "latest",
    "@octokit/rest": "latest",
    "hono": "latest",
    "valibot": "latest"
  },
  "devDependencies": {
    "@flue/cli": "latest",
    "@types/node": "latest",
    "typescript": "latest"
  }
}
